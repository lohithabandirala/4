# AegisSphere Environment Configuration
# Copy this file to .env and fill in your API keys

# Google Gemini API Key (for Pydantic AI agent)
# Required for AI-enhanced evaluation at /v1/ops/evaluate/ai
# The system works without this key using deterministic evaluation
GOOGLE_API_KEY=your_google_api_key_here

# Optional: Alternative Gemini key name
# GEMINI_API_KEY=your_gemini_api_key_here

# Server Configuration
HOST=0.0.0.0
PORT=8000
RELOAD=true
